# ============================================
# SBTI NFT — 环境配置模板
# ============================================
#
# 使用方式:
#   1. 复制此文件为 .env.testnet 或 .env.mainnet
#   2. 填入对应配置
#   3. 运行 ./deploy.sh testnet 或 ./deploy.sh mainnet
#

# 部署私钥（不要提交到 git！）
PRIVATE_KEY=your_private_key_here

# 网络配置
RPC_URL=https://bsc-testnet-rpc.publicnode.com
CHAIN_ID=97
EXPLORER_URL=https://testnet.bscscan.com

# 合约验证 API Key（可选，用于 BscScan 验证合约源码）
SCAN_API_KEY=your_api_key_here

# ============ 合约参数 ============
# Mint 价格（单位: wei）
#   测试: 100000000000000       (0.0001 BNB)
#   正式: 15000000000000000     (0.015 BNB)
MINT_PRICE=100000000000000

# 部署后是否自动调用 setMintPrice 设置价格
AUTO_SET_PRICE=true
